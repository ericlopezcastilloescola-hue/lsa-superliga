generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  player       Player?
  foundedClubs Club[]   @relation("ClubFounder")
  captainClubs Club[]   @relation("ClubCaptain")
  joinRequests JoinRequest[]
  coCaptainAssignments ClubCoCaptain[] @relation("CoCaptainMember")
  coCaptainsAssigned   ClubCoCaptain[] @relation("CoCaptainAssigner")
  matchReports         MatchReport[]
}

model Player {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  gamertag      String   @unique
  avatarUrl     String?
  position      String   @default("MID")
  nationality   String   @default("ES")
  clubId        String?
  club          Club?    @relation(fields: [clubId], references: [id], onDelete: SetNull)
  number        Int      @default(10)
  rating        Float    @default(7.0)
  goals         Int      @default(0)
  assists       Int      @default(0)
  mvpAwards     Int      @default(0)
  matchesPlayed Int      @default(0)
  createdAt     DateTime @default(now())
  transfers     TransferRecord[]
}

model Club {
  id          String   @id @default(cuid())
  name        String
  tag         String
  crestColor  String   @default("#7c3aed")
  logoUrl     String?
  founderId   String?
  founder     User?    @relation("ClubFounder", fields: [founderId], references: [id], onDelete: SetNull)
  captainId   String?
  captain     User?    @relation("ClubCaptain", fields: [captainId], references: [id], onDelete: SetNull)
  founded     Int      @default(2024)
  city        String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  players     Player[]
  compEntries CompetitionClub[]
  homeMatches Match[]  @relation("HomeClub")
  awayMatches Match[]  @relation("AwayClub")
  transfersFrom TransferRecord[] @relation("TransferFrom")
  transfersTo   TransferRecord[] @relation("TransferTo")
  joinRequests  JoinRequest[]
  coCaptains    ClubCoCaptain[]
  matchReports  MatchReport[]
}

model JoinRequest {
  id        String   @id @default(cuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@unique([clubId, userId])
}

model Competition {
  id          String   @id @default(cuid())
  name        String
  type        String
  season      String
  status      String   @default("active")
  description String   @default("")
  calendarMode  String @default("auto")
  configJson    String @default("{}")
  calendarGenerated Boolean @default(false)
  createdAt   DateTime @default(now())
  clubs       CompetitionClub[]
  matchdays   Matchday[]
  matches     Match[]
  knockoutRounds KnockoutRound[]
}

model CompetitionClub {
  competitionId String
  clubId        String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  club          Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@id([competitionId, clubId])
}

model Matchday {
  id            String   @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  number        Int
  name          String
  startDate     String
  matches       Match[]
}

model Match {
  id            String   @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  matchdayId    String?
  matchday      Matchday? @relation(fields: [matchdayId], references: [id], onDelete: SetNull)
  homeClubId    String?
  homeClub      Club?    @relation("HomeClub", fields: [homeClubId], references: [id])
  awayClubId    String?
  awayClub      Club?    @relation("AwayClub", fields: [awayClubId], references: [id])
  scheduledAt   DateTime
  status        String   @default("scheduled")
  homeScore     Int?
  awayScore     Int?
  scorers       String   @default("[]")
  assists       String   @default("[]")
  mvpPlayerId   String?
  round         String?
  feederMatchIds String?
  reports       MatchReport[]
}

model KnockoutRound {
  id            String   @id @default(cuid())
  competitionId String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  name          String
  order         Int
  matchIds      String   @default("[]")
}

model TransferRecord {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  fromClubId  String?
  fromClub    Club?    @relation("TransferFrom", fields: [fromClubId], references: [id], onDelete: SetNull)
  toClubId    String
  toClub      Club     @relation("TransferTo", fields: [toClubId], references: [id], onDelete: Cascade)
  date        String
}

model ClubCoCaptain {
  id               String   @id @default(cuid())
  clubId           String
  club             Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation("CoCaptainMember", fields: [userId], references: [id], onDelete: Cascade)
  assignedByUserId String
  assignedBy       User     @relation("CoCaptainAssigner", fields: [assignedByUserId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([clubId, userId])
}

model MatchReport {
  id            String   @id @default(cuid())
  matchId       String
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  clubId        String
  club          Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  submittedById String
  submittedBy   User     @relation(fields: [submittedById], references: [id], onDelete: Cascade)
  homeScore     Int
  awayScore     Int
  scorers       String   @default("[]")
  assists       String   @default("[]")
  mvpPlayerId   String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([matchId, clubId])
}
